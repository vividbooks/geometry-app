# Auth gate (set false to disable)
VITE_ENABLE_AUTH_GATE=false

# Auth API and redirect URLs
VITE_AUTH_CHECK_URL=https://api.vividbooks.com/v1/login
VITE_AUTH_REDIRECT_URL=https://app.vividbooks.com

# Supabase – výchozí projekt v supabasePublicDefaults.ts (https://jjpiguuubvmiobmixwgh.supabase.co).
# Úkoly ukládají do geometry_circuit_* — spusť supabase/geometry_circuit_schema.sql (ne Elobvod circuit_*).
# Nastav jen pokud chceš jiný projekt než Elobvod:
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
